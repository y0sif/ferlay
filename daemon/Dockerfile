FROM rust:1-slim AS builder
WORKDIR /app
COPY . .
RUN cargo build --release -p furlay-daemon

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/furlay-daemon /usr/local/bin/
ENTRYPOINT ["furlay-daemon"]
